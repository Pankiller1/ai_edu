# DeepSeek API Key（必填，否则系统以"演示模式"运行，返回占位内容）
DEEPSEEK_API_KEY=your_key_here

# Mimo v2.5 API Key（必填，用于图片题目识别）
MIMO_API_KEY=your_key_here

# 可选：自定义接口地址（默认官方地址）
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：模型（默认 deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_VISION_MODEL=deepseek-chat

# 可选：后端端口（默认 3001）
# PORT=3001
